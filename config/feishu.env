

# --- OpenClaw Agent ---
# 获取方式:
#   服务器上执行 `openclaw agents list` 查看所有 Agent
#   创建新 Agent: `openclaw agents add --workspace <路径> <agent-id>`
#
OPENCLAW_AGENT_ID=RSS_article
OPENCLAW_AGENT_WORKSPACE=/root/.openclaw/workspace-RSS_article

# --- 飞书群组绑定 ---
# chat_id 获取方式:
#   1. 打开飞书群组 → 右上角 ... → 设置 → 拉到最底部
#   2. 找到"群组信息" → 点击"复制"按钮
#   3. 得到的格式为 oc_xxxxxxx（去掉 "chat:" 前缀后填入）
#
# 群组策略说明:
#   allowlist = 仅允许下面 groupAllowFrom 列出的群组访问
#   open = 允许所有群组（不推荐）
#
FEISHU_GROUP_CHAT_ID=oc_97c792a037da30fe0e1079e4b63f4bf7
FEISHU_GROUP_POLICY=allowlist
